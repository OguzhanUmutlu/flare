#!/bin/bash

if [ -z "$VIRTUAL_ENV" ]; then
    echo "Sourcing venv/bin/activate..."
    source venv/bin/activate
fi

echo "Setting up vanilla-mcdoc repository..."
mkdir -p tests
if [ -d "tests/vanilla-mcdoc" ]; then
    echo "Repository exists. Pulling latest changes..."
    cd tests/vanilla-mcdoc
    git pull origin generated
    cd ../..
else
    echo "Cloning vanilla-mcdoc generated branch..."
    cd tests
    git clone --single-branch --branch generated https://github.com/SpyglassMC/vanilla-mcdoc
    cd ..
fi

echo "Running mcdoc scraper..."
python tests/scraper.py
echo "Scraping complete! Generated structures are located in flare/generated/"

echo "Running unit tests..."
for test_file in cli_test/test_*.py; do
    echo "Running $test_file..."
    output=$(flare "$test_file" --run=0 2>&1)
    if echo "$output" | grep -qi "assert"; then
        echo "Assertion failed in $test_file:"
        echo "$output"
        exit 1
    fi
done

echo "Running end-to-end tests..."
flare cli_test/main.py --run=1 2>/dev/null > tests/actual_output.raw.txt

cat tests/actual_output.raw.txt | sed -E 's/\x1b\[[0-9;]*m//g' | grep -v "Copied datapack to" | grep -v "Error parsing" | grep -v "Objective" | grep -v "Scoreboard division" | grep -v "Scoreboard modulo" | grep -v "Float(exp" | grep -v "^'$" | grep -v "Compiling" | grep -v "\[Score " | grep -v "Successfully built" | grep -v "Preprocessed in" | grep -v "Compiled in" | grep -v "\-\-\- Starting mcemu \-\-\-" | grep -v "Command not found:" | grep -v "Available commands:" | grep -v "^  - " | sed -E 's/!print_[0-9]+/!print_X/g' | sed '/^$/d' > tests/actual_output.txt

diff -u --strip-trailing-cr tests/expected_output.txt tests/actual_output.txt
DIFF_EXIT=$?

rm tests/actual_output.raw.txt tests/actual_output.txt

if [ $DIFF_EXIT -eq 0 ]; then
    echo "Tests passed!"
    if [ "$1" == "publish" ]; then
        echo "Building package..."
        rm -rf dist/
        rm -rf build/
        rm -rf *.egg-info/
        
        python -m pip install --upgrade build twine
        python -m build
        
        echo "Publishing to PyPI..."
        python -m twine upload dist/* --verbose
        rm -rf *.egg-info
        
        echo "Successfully published!"
    fi
    exit 0
else
    echo "Tests failed! See diff above."
    exit 1
fi
